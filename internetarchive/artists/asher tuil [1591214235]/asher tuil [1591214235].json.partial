        {
            "url": "https://ashertuil.bandcamp.com/album/irrealis-moods",
            "title": "irrealis moods",
            "artist": "asher tuil",
            "label": null,
            "band_id": 1591214235,
            "classification": "nyp",
            "tags": [
                "Experimental",
