---
layout: null
---
{
  "generated": "{{ site.time | date_to_xmlschema }}",
  "artists": [
    {% assign is_first = true %}
    {% for f in site.static_files %}
      {% if f.path contains '/pixeldrain/artists/' and f.extname == '.json' %}
        {% unless is_first %},{% endunless %}
        {
          "path": "{{ f.path | relative_url }}",
          "name": {{ f.basename | jsonify }}
        }
        {% assign is_first = false %}
      {% endif %}
    {% endfor %}
  ]
}
