        {
            "url": "https://coppicehalifax.bandcamp.com/album/dusk-versions-10th-anniversary-expanded-remaster",
            "title": "Dusk Versions [10th Anniversary Expanded Remaster]",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
