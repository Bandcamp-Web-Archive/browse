            ],
            "item_id": 2612935268,
            "art_id": 2779305364,
            "is_preorder": false,
            "datePublished": "07 Apr 2020 00:00:00 GMT",
            "about": "While going through tapes, thumb drives and old masters looking for other unrelated things, new cultivars are sometimes intermittently discovered. (Some hills are never seen). This half-hour deep Pharming-class cut is such an excursion, an unexpected but illuminating Coppice Halifax live techno treatment of the Milieu cut \"Evapour\" from the Daughter album. While the original track was built using a combination of FM synthesis and analog filtering/EQ, this take composts the source audio through the usual CH machinations and sends it in a completely different direction, with the addition of multiple drum machines, a bass monosynth and a Roland SH-32 playing those dripping cloud chord sequences. A bit of unexpected feelgood, at a time when I (and likely you) could use it the most. If you can't go out for some sunshine, then Coppice Halifax will bring the sunshine to you.",
            "credits": "released April 7, 2020\nW/P by Brian Grainger. Original track recorded at White Pillar, 2018. Remix produced and performed at White Pillar, April 2020. Mastered by The Analog Botanist. Text and design by ABM&D. This is Milieu Music number ABX108.",
            "license": "all rights reserved",
            "coverUrl_0": "https://f4.bcbits.com/img/a2779305364_0",
            "trackinfo": [
                {
                    "title": "Evapour [Springpharming Dub]",
                    "duration": "31:12",
                    "lyrics": null,
                    "label": "Milieu Music Digital",
                    "track_id": 1968065748,
                    "track_num": "1",
                    "artist": "Milieu",
