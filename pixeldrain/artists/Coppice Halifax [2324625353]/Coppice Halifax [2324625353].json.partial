        {
            "url": "https://coppicehalifax.bandcamp.com/album/cirkauita-surrounded",
            "title": "Cirkauita / Surrounded",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Berlin School",
                "Electronic",
                "ambient",
                "ambient electronic",
                "analog",
                "braindance",
                "drone",
                "dub techno",
