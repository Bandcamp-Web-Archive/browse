        {
            "url": "https://coppicehalifax.bandcamp.com/album/cvx3",
            "title": "CVX3",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient techno",
                "braindance",
                "clicks & cuts",
                "deep techno",
                "dub techno",
                "glitch",
