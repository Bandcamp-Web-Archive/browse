        {
            "url": "https://coppicehalifax.bandcamp.com/album/arbaro-liberigo",
            "title": "Arbaro Liberigo",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "ambient techno",
                "braindance",
                "deep",
                "dub",
                "dub tech",
                "dub techno",
                "idm",
                "jaymon",
                "minimal",
                "minimal techno",
                "nemo",
                "techno",
                "the nautilus project",
                "Cleveland"
            ],
            "item_id": 2442169569,
            "art_id": 2477442178,
            "is_preorder": false,
            "datePublished": "31 May 2016 00:00:00 GMT",
            "about": "Arbaro Liberigo is a monument that exists in two worlds - the first being the Deep Earth universe, where it bears the previously mentioned name, the second being the Forest Roots universe, somewhere deep in the woods of Germany, where it has been christened by carving the name Forest Liberation into a thick tree trunk. This mammoth piece of psychedelic techno has been constructed by Nemo (aka The Nautilus Project) & Jaymon, using the entirety of the first year of Deep Earth's catalog as sound source, along with various devices from the Forest Roots studio and field recordings Nemo & Jaymon have captured in their extensive travels. It represents a true meeting of the minds, coalescing like a gigantic fog that hangs above South Carolina and Germany in tandem, and it also begins a Deep Earth catalog subset called Ripetis, or \"Reiterated\", which will serve as a vessel for Deep Earth reconstructions, remix works and excavations by external producers and studios.",
            "credits": "released May 31, 2016\nWritten by Coppice Halifax. Remixed, produced and liberated by Nemo & Jaymon. Nemo & Jaymon appear on Deep Earth courtesy of Forest Roots, DE. Mastered by Forest Roots. Cover photography by Brian Grainger. This is Milieu Music number [RIPETIS 1]. © + ℗ Milieu Music & Forest Roots, 2016.",
            "license": "all rights reserved",
            "coverUrl_0": "https://f4.bcbits.com/img/a2477442178_0",
            "trackinfo": [
                {
                    "title": "Deep Earth [Forest Liberation By Nemo & Jaymon]",
                    "duration": "51:52",
                    "lyrics": null,
                    "label": "Milieu Music Digital",
                    "track_id": 3960831711,
                    "track_num": "1",
                    "artist": "Coppice Halifax",
                    "url": "https://coppicehalifax.bandcamp.com/track/deep-earth-forest-liberation-by-nemo-jaymon",
                    "trackCoverUrl_0": "https://f4.bcbits.com/img/a2477442178_0",
                    "art_id": 2477442178,
                    "about": null,
                    "credits": "from Arbaro Liberigo, released May 31, 2016",
                    "license": "all rights reserved"
                }
            ]
        },
        {
