        {
            "url": "https://coppicehalifax.bandcamp.com/album/cmx-volumes-viii-xv",
            "title": "Cmx [Volumes VIII-XV]",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient techno",
                "braindance",
                "dance",
                "deep house",
                "downtempo",
                "dub",
                "dub techno",
                "electro",
