        {
            "url": "https://coppicehalifax.bandcamp.com/album/auroral-phases",
            "title": "Auroral Phases",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "braindance",
