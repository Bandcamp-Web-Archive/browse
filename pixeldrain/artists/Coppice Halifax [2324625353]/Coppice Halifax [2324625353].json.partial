        {
            "url": "https://coppicehalifax.bandcamp.com/album/chemist-cloak",
            "title": "Chemist Cloak",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "ambient techno",
                "braindance",
                "deep",
                "deep techno",
                "dub",
                "dub tech",
                "dub techno",
                "idm",
