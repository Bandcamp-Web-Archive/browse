                    "art_id": 2779305364,
                    "about": null,
                    "credits": "from Evapour Version, released April 7, 2020",
                    "license": "all rights reserved"
                }
            ]
        },
        {
            "url": "https://coppicehalifax.bandcamp.com/album/familiar-shores-2",
            "title": "Familiar Shores",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "ambient house",
                "ambient techno",
                "braindance",
                "deep techno",
                "drone techno",
                "dub",
                "dub tech",
                "dub techno",
                "idm",
