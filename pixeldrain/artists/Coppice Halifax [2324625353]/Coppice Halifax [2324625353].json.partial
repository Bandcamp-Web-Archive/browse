        {
            "url": "https://coppicehalifax.bandcamp.com/album/cedar-mast-expanded-remastered",
            "title": "Cedar Mast [Expanded & Remastered]",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient techno",
                "braindance",
                "deep house",
                "deep techno",
                "dub",
