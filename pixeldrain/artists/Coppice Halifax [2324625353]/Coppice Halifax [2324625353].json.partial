        {
            "url": "https://coppicehalifax.bandcamp.com/album/ash-cloak",
            "title": "Ash Cloak",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "braindance",
                "deepwarmth",
                "dub",
                "dub tech",
                "dub techno",
                "dubtech",
                "dubtechno",
                "idm",
                "lamont kohner",
                "techno",
                "textural being",
                "zander one",
                "Cleveland"
            ],
            "item_id": 3514852102,
            "art_id": 3972297808,
            "is_preorder": false,
            "datePublished": "05 Jun 2013 00:00:00 GMT",
            "about": "Leaf Cloak, remixed! A colorful and consistent set of ten remixes by Textural Being (acting here under his aspect. alias), Zander One, Lamont Kohner, DeepWarmth, Dorosoto, Time For Trees, TKM and a couple mixes of Fissure by a producer who shall remain nameless. Minimal house grooves collide with ambient extractions and dub techno rebuilds, until the whole thing sinks beneath the waves of DeepWarmth's submersible excursion. Lush organic techno sculptures, ready for your Summer driving or your evening wind-down.",
            "credits": "released June 5, 2013\nWritten by Brian Grainger. Remixed and produced by the credited artists. Mastered by The Analog Botanist at Botany Bay, May 2013. Five and ten are linking books to ABX22. This is Milieu Music number ABX21.",
            "license": "all rights reserved",
