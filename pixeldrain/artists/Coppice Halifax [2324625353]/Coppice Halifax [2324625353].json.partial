                    "credits": "from CVX3, released April 2, 2021",
                    "license": "all rights reserved"
                },
                {
                    "title": "Centrevalley",
                    "duration": "11:26",
                    "lyrics": null,
                    "label": "Milieu Music Digital",
                    "track_id": 836708724,
