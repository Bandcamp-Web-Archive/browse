        {
            "url": "https://coppicehalifax.bandcamp.com/album/cmx-viii",
            "title": "Cmx VIII",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
