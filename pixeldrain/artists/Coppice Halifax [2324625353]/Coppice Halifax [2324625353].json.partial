        {
            "url": "https://coppicehalifax.bandcamp.com/album/deep-earth-year-four-compleat",
            "title": "Deep Earth: Year Four Compleat",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient techno",
                "braindance",
                "deep techno",
                "drone",
                "dub",
                "dub tech",
