        {
            "url": "https://coppicehalifax.bandcamp.com/album/coastal-reveries",
            "title": "Coastal Reveries",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "ambient techno",
                "braindance",
                "chillout",
                "deep",
                "deep techno",
