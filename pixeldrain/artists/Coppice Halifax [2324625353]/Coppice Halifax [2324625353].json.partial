        {
            "url": "https://coppicehalifax.bandcamp.com/album/arctic-liner-disintegration-expanded",
            "title": "Arctic Liner Disintegration [Expanded]",
            "artist": "Coppice Halifax",
            "label": "Milieu Music Digital",
            "band_id": 2324625353,
            "classification": "paid",
            "tags": [
                "Electronic",
                "ambient",
                "ambient dub",
                "braindance",
                "deep",
                "deep techno",
                "drone",
                "drone techno",
                "dub",
                "dub techno",
                "idm",
                "minimal dub",
                "minimal techno",
                "techno",
                "tropical",
                "Cleveland"
            ],
            "item_id": 220196221,
            "art_id": 3342297190,
            "is_preorder": false,
            "datePublished": "03 Jul 2020 03:09:19 GMT",
            "about": "Originally recorded as a beatless and extended alternative mix of \"Equatorial Haze\" from High Hawaiian Fog, Arctic Liner Disintegration appeared briefly in physical form as a bonus 3\" mini-CDR included with preorders of the High Hawaiian Fog LP. Having also been subsequently included in the Collected Drone Works double-album compilation, this solo release is the first time it has appeared in its own time and space on Bandcamp. For the occasion, I sporadically decided to attempt a \"dub\" of the track using the original session tape alongside a sampler containing two drum breaks used on \"Equatorial Haze\" and a bass monosynth. The result of this session is \"Arctic Liner Dub\", a brand new perspective on the High Hawaiian Fog sound that seems to be informed a bit more by Tigress. Huge, deep and droned out, it pulls me back to the splashing waves and salty sand of those headspaces.",
            "credits": "released July 3, 2020\nW/P by Brian Grainger. #1 recorded at Rolling Knoll, 2011. #2 recorded at White Pillar, June 2020. Mastered by The Analog Botanist. Design and text by ABM&D. This is Milieu Music number AD10B.  www.milieu-music.com  /  www.analogbotany.com",
            "license": "all rights reserved",
            "coverUrl_0": "https://f4.bcbits.com/img/a3342297190_0",
